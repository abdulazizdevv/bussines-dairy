<w:document xmlns:wpc="http://schemas.microsoft.com/office/word/2010/wordprocessingCanvas" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships" xmlns:m="http://schemas.openxmlformats.org/officeDocument/2006/math" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:wp14="http://schemas.microsoft.com/office/word/2010/wordprocessingDrawing" xmlns:wp="http://schemas.openxmlformats.org/drawingml/2006/wordprocessingDrawing" xmlns:w="http://schemas.openxmlformats.org/wordprocessingml/2006/main" xmlns:w14="http://schemas.microsoft.com/office/word/2010/wordml" xmlns:w10="urn:schemas-microsoft-com:office:word" xmlns:w15="http://schemas.microsoft.com/office/word/2012/wordml" xmlns:wpg="http://schemas.microsoft.com/office/word/2010/wordprocessingGroup" xmlns:wpi="http://schemas.microsoft.com/office/word/2010/wordprocessingInk" xmlns:wne="http://schemas.microsoft.com/office/word/2006/wordml" xmlns:wps="http://schemas.microsoft.com/office/word/2010/wordprocessingShape" xmlns:wpsCustomData="http://www.wps.cn/officeDocument/2013/wpsCustomData" mc:Ignorable="w14 w15 wp14"><w:body><w:p w14:paraId="28F4B1D6"><w:pPr><w:rPr><w:rFonts w:hint="default" w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:cs="Times New Roman"/><w:b/><w:bCs/><w:sz w:val="36"/><w:szCs w:val="36"/><w:lang w:val="en-US"/></w:rPr></w:pPr><w:r><w:rPr><w:rFonts w:hint="default" w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:cs="Times New Roman"/><w:b/><w:bCs/><w:sz w:val="36"/><w:szCs w:val="36"/><w:lang w:val="en-US"/></w:rPr><w:t>Starbucks startupi bilan qizqacha tanishuv:</w:t></w:r></w:p><w:p w14:paraId="621E24C7"><w:pPr><w:pStyle w:val="7"/><w:keepNext w:val="0"/><w:keepLines w:val="0"/><w:widowControl/><w:suppressLineNumbers w:val="0"/><w:spacing w:before="0" w:beforeAutospacing="1" w:after="0" w:afterAutospacing="1"/><w:ind w:left="0" w:right="0"/><w:rPr><w:rFonts w:hint="default" w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:eastAsia="SimSun" w:cs="Times New Roman"/><w:sz w:val="24"/><w:szCs w:val="24"/></w:rPr></w:pPr><w:r><w:t xml:space="preserve">Starbucks 1971 yilda Jerry Baldwin, Gordon Bowker va Zev Siegl tomonidan Seattledagi tarixiy Pike Place Market yaqinida ochildi. Uch asoschining ikkita umumiy jihati bor edi: </w:t></w:r><w:r><w:rPr><w:rFonts w:hint="default"/><w:lang w:val="en-US"/></w:rPr><w:t xml:space="preserve">uchchalasi </w:t></w:r><w:r><w:t xml:space="preserve">ham akademiya vakillari va </w:t></w:r><w:r><w:rPr><w:rFonts w:hint="default"/><w:lang w:val="en-US"/></w:rPr><w:t xml:space="preserve">uchchalasi </w:t></w:r><w:r><w:t>ham qahvani juda yaxshi ko'rishardi.</w:t></w:r><w:r><w:rPr><w:rFonts w:hint="default"/><w:lang w:val="en-US"/></w:rPr><w:t xml:space="preserve"> </w:t></w:r><w:r><w:t>Dastlabki Starbucks kafe emas edi — u butun qahva</w:t></w:r><w:r><w:rPr><w:rFonts w:hint="default"/><w:lang w:val="en-US"/></w:rPr><w:t xml:space="preserve"> donachalarini</w:t></w:r><w:r><w:t>, choy va qahva uskunalarini sotuvchi maxsus do'kon edi. Uning maqsadi savdo qilish bilan birga odamlarga qahva qaerdan kelishi, uni qanday tortish va qanday tayyorlashni o'rgatish edi. Kompaniya nomi &quot;st&quot; harflari bilan boshlanadigan so'zlarni qidirayotganda topilgan — Gordon Bowker &quot;st&quot; bilan boshlanadigan nomlar muvaffaqiyatli brendlarda ko'p uchraydi, deb hisoblardi. Shunday qilib Herman Melville'ning &quot;Moby Dick&quot; romanidagi birinchi shterman Starbuck nomi tanlandi.</w:t></w:r><w:r><w:rPr><w:rFonts w:hint="default"/><w:lang w:val="en-US"/></w:rPr><w:t xml:space="preserve"> </w:t></w:r><w:r><w:rPr><w:rFonts w:hint="default" w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:eastAsia="SimSun" w:cs="Times New Roman"/><w:sz w:val="24"/><w:szCs w:val="24"/></w:rPr><w:t xml:space="preserve">1982 yilda Howard Schultz nomli yosh </w:t></w:r><w:r><w:rPr><w:rFonts w:hint="default" w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:eastAsia="SimSun" w:cs="Times New Roman"/><w:sz w:val="24"/><w:szCs w:val="24"/><w:lang w:val="en-US"/></w:rPr><w:t>Nyu</w:t></w:r><w:r><w:rPr><w:rFonts w:hint="default" w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:eastAsia="SimSun" w:cs="Times New Roman"/><w:sz w:val="24"/><w:szCs w:val="24"/></w:rPr><w:t>yorklik Starbucks do'koniga kir</w:t></w:r><w:r><w:rPr><w:rFonts w:hint="default" w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:eastAsia="SimSun" w:cs="Times New Roman"/><w:sz w:val="24"/><w:szCs w:val="24"/><w:lang w:val="en-US"/></w:rPr><w:t>ib b qultum ichib ko’rgach</w:t></w:r><w:r><w:rPr><w:rFonts w:hint="default" w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:eastAsia="SimSun" w:cs="Times New Roman"/><w:sz w:val="24"/><w:szCs w:val="24"/></w:rPr><w:t xml:space="preserve"> qahvaga mahliyo bo'ldi.</w:t></w:r><w:r><w:rPr><w:rFonts w:hint="default" w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:eastAsia="SimSun" w:cs="Times New Roman"/><w:sz w:val="24"/><w:szCs w:val="24"/><w:lang w:val="en-US"/></w:rPr><w:t xml:space="preserve"> </w:t></w:r><w:r><w:rPr><w:rFonts w:hint="default" w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:eastAsia="SimSun" w:cs="Times New Roman"/><w:sz w:val="24"/><w:szCs w:val="24"/></w:rPr><w:t>1983 yilda Milanga safari uni Italiya qahvaxonalari madaniyatidan ilhomlantirib qaytdi va shu issiqlik va san'atni Starbucksga olib kelish niyatiga tushdi.</w:t></w:r></w:p><w:p w14:paraId="7DD77FBA"><w:pPr><w:pStyle w:val="7"/><w:keepNext w:val="0"/><w:keepLines w:val="0"/><w:widowControl/><w:suppressLineNumbers w:val="0"/><w:spacing w:before="0" w:beforeAutospacing="1" w:after="0" w:afterAutospacing="1"/><w:ind w:left="0" w:right="0"/><w:rPr><w:rFonts w:hint="default" w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:eastAsia="SimSun" w:cs="Times New Roman"/><w:b/><w:bCs/><w:sz w:val="36"/><w:szCs w:val="36"/><w:lang w:val="en-US"/></w:rPr></w:pPr><w:r><w:rPr><w:rFonts w:hint="default" w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:eastAsia="SimSun" w:cs="Times New Roman"/><w:b/><w:bCs/><w:sz w:val="36"/><w:szCs w:val="36"/><w:lang w:val="en-US"/></w:rPr><w:t>Startbucks muvavfaqiyatga erishish yo’li:</w:t></w:r></w:p><w:p w14:paraId="63F9EB18"><w:pPr><w:pStyle w:val="7"/><w:keepNext w:val="0"/><w:keepLines w:val="0"/><w:widowControl/><w:suppressLineNumbers w:val="0"/><w:spacing w:before="0" w:beforeAutospacing="1" w:after="0" w:afterAutospacing="1"/><w:ind w:left="0" w:right="0"/><w:rPr><w:rFonts w:hint="default" w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:eastAsia="sans-serif" w:cs="Times New Roman"/><w:i w:val="0"/><w:iCs w:val="0"/><w:caps w:val="0"/><w:color w:val="3D3D3A"/><w:spacing w:val="0"/><w:sz w:val="24"/><w:szCs w:val="24"/><w:lang w:val="en-US"/></w:rPr></w:pPr><w:r><w:rPr><w:rFonts w:hint="default" w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:eastAsia="SimSun" w:cs="Times New Roman"/><w:sz w:val="24"/><w:szCs w:val="24"/></w:rPr><w:t>Howard Schultz</w:t></w:r><w:r><w:rPr><w:rFonts w:hint="default" w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:eastAsia="SimSun" w:cs="Times New Roman"/><w:sz w:val="24"/><w:szCs w:val="24"/><w:lang w:val="en-US"/></w:rPr><w:t xml:space="preserve"> dastlabki asoschilardan bu startupni sotib olganida atiga 11 dona do’kon mavjud edi. U do’konni kattaytirish uchun investrorlarga murojat qidi ammo u 217 martta yo’q javobini eshitsada qayta qayta urinib ko’rdi va 218chisida o’ziga investor topdi. Keyinchalik u bu kompaniyani mijozning uyi va ishxonasi o’rtasidagi dam olish uchun joy qilib shakillantirdi va bu mijozlarga juda ham yoqdi. Keyinchalik 2004 yilga kelib uning do’konlarining soni 7000 mingtaga yetgan. Howard Schultz kompaniyani tizimlashtirgandan so’ng CEO sifatida boshqasiga topshiradi. Ammo 2007 yilga kelib kompaniya inqiroz yoqasiga kelib qolgan edi deyarli 900ga yaqin do’konlarini yopishga majbur bo’lgan. Yangi CEO </w:t></w:r><w:r><w:rPr><w:rFonts w:hint="default" w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:eastAsia="sans-serif" w:cs="Times New Roman"/><w:i w:val="0"/><w:iCs w:val="0"/><w:caps w:val="0"/><w:color w:val="3D3D3A"/><w:spacing w:val="0"/><w:sz w:val="24"/><w:szCs w:val="24"/></w:rPr><w:t xml:space="preserve">2007 yilga kelib </w:t></w:r><w:r><w:rPr><w:rFonts w:hint="default" w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:eastAsia="sans-serif" w:cs="Times New Roman"/><w:i w:val="0"/><w:iCs w:val="0"/><w:caps w:val="0"/><w:color w:val="3D3D3A"/><w:spacing w:val="0"/><w:sz w:val="24"/><w:szCs w:val="24"/><w:lang w:val="en-US"/></w:rPr><w:t>a</w:t></w:r><w:r><w:rPr><w:rFonts w:hint="default" w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:eastAsia="sans-serif" w:cs="Times New Roman"/><w:i w:val="0"/><w:iCs w:val="0"/><w:caps w:val="0"/><w:color w:val="3D3D3A"/><w:spacing w:val="0"/><w:sz w:val="24"/><w:szCs w:val="24"/></w:rPr><w:t>vtomatik espresso mashinalari o'rnati</w:t></w:r><w:r><w:rPr><w:rFonts w:hint="default" w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:eastAsia="sans-serif" w:cs="Times New Roman"/><w:i w:val="0"/><w:iCs w:val="0"/><w:caps w:val="0"/><w:color w:val="3D3D3A"/><w:spacing w:val="0"/><w:sz w:val="24"/><w:szCs w:val="24"/><w:lang w:val="en-US"/></w:rPr><w:t>rdi</w:t></w:r><w:r><w:rPr><w:rFonts w:hint="default" w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:eastAsia="sans-serif" w:cs="Times New Roman"/><w:i w:val="0"/><w:iCs w:val="0"/><w:caps w:val="0"/><w:color w:val="3D3D3A"/><w:spacing w:val="0"/><w:sz w:val="24"/><w:szCs w:val="24"/></w:rPr><w:t xml:space="preserve"> — tezroq, arzonroq. Lekin baristaning qo'li ko'rinmaydigan bo'ld</w:t></w:r><w:r><w:rPr><w:rFonts w:hint="default" w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:eastAsia="sans-serif" w:cs="Times New Roman"/><w:i w:val="0"/><w:iCs w:val="0"/><w:caps w:val="0"/><w:color w:val="3D3D3A"/><w:spacing w:val="0"/><w:sz w:val="24"/><w:szCs w:val="24"/><w:lang w:val="en-US"/></w:rPr><w:t xml:space="preserve">i va bu yondashuv mijozlarga hush kelmadi. 2008 yilda yana boshqaruvni tepasiga Howard Schultz keldi va kofni oldingi kabi qo’lda tayyorlash usulini yana joriy etdi va kompaniya aksilalarini 3 barobarga oshirdi. </w:t></w:r><w:r><w:rPr><w:rFonts w:hint="default" w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:eastAsia="sans-serif" w:cs="Times New Roman"/><w:i w:val="0"/><w:iCs w:val="0"/><w:color w:val="3D3D3A"/><w:spacing w:val="0"/><w:sz w:val="24"/><w:szCs w:val="24"/><w:lang w:val="en-US"/></w:rPr><w:t>O</w:t></w:r><w:r><w:rPr><w:rFonts w:hint="default" w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:eastAsia="sans-serif" w:cs="Times New Roman"/><w:i w:val="0"/><w:iCs w:val="0"/><w:caps w:val="0"/><w:color w:val="3D3D3A"/><w:spacing w:val="0"/><w:sz w:val="24"/><w:szCs w:val="24"/><w:lang w:val="en-US"/></w:rPr><w:t>xirgi Ceo Brian Niccol o’z strategiyasiga m</w:t></w:r><w:r><w:rPr><w:rFonts w:hint="default" w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:eastAsia="sans-serif" w:cs="Times New Roman"/><w:i w:val="0"/><w:iCs w:val="0"/><w:caps w:val="0"/><w:color w:val="3D3D3A"/><w:spacing w:val="0"/><w:sz w:val="24"/><w:szCs w:val="24"/></w:rPr><w:t>ijozlar uchun qulay o'rindiqlar, keramik piyolalar, bepul qoshimcha qahva, shaxsiy xabarlar yozilgan stakanchalar</w:t></w:r><w:r><w:rPr><w:rFonts w:hint="default" w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:eastAsia="sans-serif" w:cs="Times New Roman"/><w:i w:val="0"/><w:iCs w:val="0"/><w:caps w:val="0"/><w:color w:val="3D3D3A"/><w:spacing w:val="0"/><w:sz w:val="24"/><w:szCs w:val="24"/><w:lang w:val="en-US"/></w:rPr><w:t>ni qo’shdi va bu savdoni juda ham ko’tarib yubordi. Startbucks ochilganidan beri 9000 foziga oshdi va 38000dan ortiq do’konlar ochdi. Buning asosiy sababi u qolganlarga o’xshab firanshizalar orqali agressiv kengayish yo’lini tanlamadi, balki u har bir do’konni ozi ochdi va shu orqali har bir do’konda o’z standartlarini saqlab qola oldi.</w:t></w:r></w:p><w:p w14:paraId="7EF701B8"><w:pPr><w:pStyle w:val="7"/><w:keepNext w:val="0"/><w:keepLines w:val="0"/><w:widowControl/><w:suppressLineNumbers w:val="0"/><w:spacing w:before="0" w:beforeAutospacing="1" w:after="0" w:afterAutospacing="1"/><w:ind w:left="0" w:right="0"/><w:rPr><w:rFonts w:hint="default" w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:eastAsia="sans-serif" w:cs="Times New Roman"/><w:b/><w:bCs/><w:i w:val="0"/><w:iCs w:val="0"/><w:caps w:val="0"/><w:color w:val="3D3D3A"/><w:spacing w:val="0"/><w:sz w:val="36"/><w:szCs w:val="36"/><w:lang w:val="en-US"/></w:rPr></w:pPr><w:r><w:rPr><w:rFonts w:hint="default" w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:eastAsia="sans-serif" w:cs="Times New Roman"/><w:b/><w:bCs/><w:i w:val="0"/><w:iCs w:val="0"/><w:color w:val="3D3D3A"/><w:spacing w:val="0"/><w:sz w:val="36"/><w:szCs w:val="36"/><w:lang w:val="en-US"/></w:rPr><w:t>O</w:t></w:r><w:r><w:rPr><w:rFonts w:hint="default" w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:eastAsia="sans-serif" w:cs="Times New Roman"/><w:b/><w:bCs/><w:i w:val="0"/><w:iCs w:val="0"/><w:caps w:val="0"/><w:color w:val="3D3D3A"/><w:spacing w:val="0"/><w:sz w:val="36"/><w:szCs w:val="36"/><w:lang w:val="en-US"/></w:rPr><w:t>linishi kerak bo’lgan muhim xulosalar:</w:t></w:r></w:p><w:p w14:paraId="37FCFC0C"><w:pPr><w:pStyle w:val="7"/><w:keepNext w:val="0"/><w:keepLines w:val="0"/><w:widowControl/><w:suppressLineNumbers w:val="0"/></w:pPr><w:r><w:t>Xulosa qilib aytganda, Starbucks muvaffaqiyati tasodif emas, balki</w:t></w:r><w:r><w:rPr><w:rFonts w:hint="default"/><w:lang w:val="en-US"/></w:rPr><w:t xml:space="preserve"> bu</w:t></w:r><w:r><w:t xml:space="preserve"> qat’iyat, to‘g‘ri strategiya va mijoz ehtiyojini chuqur tushunish natijasidir</w:t></w:r><w:bookmarkStart w:id="0" w:name="_GoBack"/><w:bookmarkEnd w:id="0"/><w:r><w:t>. Kompaniya nafaqat qahva sotdi, balki insonlar uchun qulay muhit — “uchinchi joy” konsepsiyasini yaratdi. Howard Schultzning taslim bo‘lmasligi, doimiy izlanishi va sifatga bo‘lgan e’tibori Starbucksni oddiy do‘kondan global brend darajasiga olib chiqdi. Bu hikoya shuni ko‘rsatadiki, haqiqiy muvaffaqiyat sabr, qat’iylik va mijozga qiymat berish orqali keladi.</w:t></w:r></w:p><w:p w14:paraId="5446B2D3"><w:pPr><w:pStyle w:val="7"/><w:keepNext w:val="0"/><w:keepLines w:val="0"/><w:widowControl/><w:suppressLineNumbers w:val="0"/><w:spacing w:before="0" w:beforeAutospacing="1" w:after="0" w:afterAutospacing="1"/><w:ind w:left="0" w:right="0"/><w:rPr><w:rFonts w:hint="default" w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:eastAsia="sans-serif" w:cs="Times New Roman"/><w:b/><w:bCs/><w:i w:val="0"/><w:iCs w:val="0"/><w:caps w:val="0"/><w:color w:val="3D3D3A"/><w:spacing w:val="0"/><w:sz w:val="36"/><w:szCs w:val="36"/><w:lang w:val="en-US"/></w:rPr></w:pPr></w:p><w:p w14:paraId="768D580A"><w:pPr><w:pStyle w:val="7"/><w:keepNext w:val="0"/><w:keepLines w:val="0"/><w:widowControl/><w:suppressLineNumbers w:val="0"/><w:spacing w:before="0" w:beforeAutospacing="1" w:after="0" w:afterAutospacing="1"/><w:ind w:left="0" w:right="0"/><w:rPr><w:rFonts w:hint="default" w:ascii="Times New Roman" w:hAnsi="Times New Roman" w:eastAsia="sans-serif" w:cs="Times New Roman"/><w:b w:val="0"/><w:bCs w:val="0"/><w:i w:val="0"/><w:iCs w:val="0"/><w:caps w:val="0"/><w:color w:val="3D3D3A"/><w:spacing w:val="0"/><w:sz w:val="24"/><w:szCs w:val="24"/><w:lang w:val="en-US"/></w:rPr></w:pPr></w:p><w:p w14:paraId="6609FB99"><w:pPr><w:rPr><w:rFonts w:hint="default"/><w:lang w:val="en-US"/></w:rPr></w:pPr></w:p><w:p w14:paraId="183FBAD2"><w:pPr><w:rPr><w:rFonts w:hint="default"/><w:b/><w:bCs/><w:lang w:val="en-US"/></w:rPr></w:pPr></w:p><w:sectPr><w:pgSz w:w="11906" w:h="16838"/><w:pgMar w:top="1440" w:right="1800" w:bottom="1440" w:left="1800" w:header="720" w:footer="720" w:gutter="0"/><w:cols w:space="720" w:num="1"/><w:docGrid w:linePitch="360" w:charSpace="0"/></w:sectPr></w:body></w:document>