---
import { getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import BlogCard from '../../components/BlogCard.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { slug } = Astro.params;
const { post } = Astro.props;
const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const relatedPosts = allPosts.filter((item) => item.id !== slug).slice(0, 3);
const { Content } = await render(post);
---

<!doctype html>
<html lang='uz'>
  <head>
    <BaseHead
      title={post.data.title}
      description={post.data.excerpt}
      image={post.data.heroImage}
    />
  </head>
  <body>
    <Header />
    <main>
      <div class='mx-auto w-full max-w-[1120px] px-4 pt-8'>
        <a
          href='/'
          class='text-sm text-[#6f6458] transition-colors hover:text-[#2d251f]'
          >&larr; Barcha maqolalar</a
        >
      </div>

      <article class='mx-auto w-full max-w-[840px] px-4 pb-16 pt-4'>
        <div>
          <span
            class='inline-block text-xs font-semibold uppercase tracking-[0.14em] text-[#e78722]'
            >{post.data.category}</span
          >
          <h1
            class='mt-4 text-4xl font-bold leading-tight text-[#2d251f] md:text-6xl'
          >
            {post.data.title}
          </h1>
          <div class='mt-4 flex items-center gap-2 text-sm text-[#6f6458]'>
            <span>{post.data.pubDate.toISOString().slice(0, 10)}</span>
            <span>·</span>
            <span>{post.data.readTime}</span>
          </div>
        </div>

        <div class='my-10 overflow-hidden rounded-lg'>
          <img
            src={post.data.heroImage}
            alt={post.data.title}
            class='block h-auto w-full'
          />
        </div>

        <div
          class='[&_h2]:mt-10 [&_h2]:mb-3 [&_h2]:text-3xl [&_h2]:font-bold [&_h2]:text-[#2d251f] [&_p]:leading-relaxed [&_p]:text-[#6f6458] [&_ul]:ml-5 [&_ul]:list-disc [&_ol]:ml-5 [&_ol]:list-decimal [&_li]:text-[#6f6458] [&_strong]:text-[#2d251f]'
        >
          <Content />
        </div>
      </article>

      <section class='bg-[#f3ede1] py-20'>
        <div class='mx-auto w-full max-w-[1120px] px-4'>
          <h2 class='mb-8 text-3xl font-bold text-[#2d251f]'>
            Boshqa maqolalar
          </h2>
          <div class='grid gap-10 md:grid-cols-2 lg:grid-cols-3'>
            {relatedPosts.map((item) => <BlogCard post={item} />)}
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
