---
import BaseHead from "../../components/BaseHead.astro";
import BlogCard from "../../components/BlogCard.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import { getCollection } from "astro:content";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="uz">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="mx-auto w-full max-w-[1120px] px-4 py-20">
			<div class="text-xs font-bold uppercase tracking-[0.14em] text-[#e78722]">Barcha maqolalar</div>
			<h1 class="mb-8 mt-2 text-4xl font-bold text-[#2d251f]">Bizness Kundalik Blog</h1>
			<div class="grid gap-10 md:grid-cols-2 lg:grid-cols-3">
				{
					posts.map((post) => (
						<BlogCard post={post} />
					))
				}
			</div>
		</main>
		<Footer />
	</body>
</html>
